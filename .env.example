# ─── Firebase ────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON file
FIREBASE_CREDENTIAL_PATH=./firebase-service-account.json

# ─── Business Client ──────────────────────────────────────────────────────────
# Your unique business client ID stored in Firestore.
# This is used as a default when Retell AI doesn't pass client_id in tool calls.
CLIENT_ID=your-client-id-here

# ─── Application ─────────────────────────────────────────────────────────────
# Set to "development" to enable debug logging, or "production" to disable it
APP_ENV=development

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8090
