# ─── Firebase ────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON file
FIREBASE_CREDENTIAL_PATH=./firebase-service-account.json

# ─── Business Client ──────────────────────────────────────────────────────────
# Default client ID — used as fallback when assistantId is not provided
CLIENT_ID=your-client-id-here

# ─── Application ─────────────────────────────────────────────────────────────
# "development" enables debug logging, "production" disables it
APP_ENV=development

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8090

# ─── JWT Authentication ──────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-64-char-random-hex-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Admin Credentials ───────────────────────────────────────────────────────
# Change these before deploying to production!
# The admin account is pre-seeded — see seed_firestore.py
ADMIN_USERNAME=automite_admin
ADMIN_PASSWORD=Aut0m!te@Secure#2026

# ─── Vapi AI ─────────────────────────────────────────────────────────────────
# Get your key from: https://dashboard.vapi.ai
VAPI_API_KEY=
VAPI_TEMPLATE_ASSISTANT_ID=e8595039-80c0-4c78-a84c-8aff64d40407

# ─── Google OAuth2 (Calendar Integration) ────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Encryption ──────────────────────────────────────────────────────────────
# Fernet key for encrypting stored tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# ─── Public base URL ─────────────────────────────────────────────────────────
BASE_URL=http://localhost:8090
